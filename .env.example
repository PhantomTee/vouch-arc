# --- Arc testnet deploy ---
# Private key of the deployer / protocol arbiter wallet (fund it from https://faucet.circle.com)
PRIVATE_KEY=0xYourDeployerPrivateKey

# Override the default Arc testnet RPC if you have a dedicated endpoint (e.g. Alchemy)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Optional: separate arbiter / fee sink. Defaults to the deployer address.
PROTOCOL_WALLET=
# Protocol fee in basis points (250 = 2.5%, max 1000 = 10%)
PROTOCOL_FEE_BPS=250

# Filled in after `npm run deploy:arc` — consumed by the off-chain marketplace/agents
ESCROW_ADDRESS=

# Arcscan verification (optional, not required on testnet)
ARCSCAN_API_KEY=
